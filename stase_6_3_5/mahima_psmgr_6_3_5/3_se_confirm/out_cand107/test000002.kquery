array out_offset[4] : w32 -> w8 = symbolic
array role_managed[4] : w32 -> w8 = symbolic
array token[4] : w32 -> w8 = symbolic
array wl1[4] : w32 -> w8 = symbolic
array wl2[4] : w32 -> w8 = symbolic
(query [(Eq false
             (Eq 0
                 (ReadLSB w32 0 role_managed)))
         (Eq 0
             (ReadLSB w32 0 token))
         (Eq 132
             (ReadLSB w32 0 wl1))
         (Ult (ReadLSB w32 0 out_offset)
              128)
         (Eq false
             (Eq 128
                 (ReadLSB w32 0 wl2)))]
        false)
