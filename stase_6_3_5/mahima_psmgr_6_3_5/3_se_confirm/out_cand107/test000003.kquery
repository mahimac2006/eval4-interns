array copy_len[4] : w32 -> w8 = symbolic
array out_offset[4] : w32 -> w8 = symbolic
array role_managed[4] : w32 -> w8 = symbolic
array role_secondary[4] : w32 -> w8 = symbolic
array secondary_limit[4] : w32 -> w8 = symbolic
array token[4] : w32 -> w8 = symbolic
array window_sz[4] : w32 -> w8 = symbolic
array wl1[4] : w32 -> w8 = symbolic
array wl2[4] : w32 -> w8 = symbolic
array write_limit[4] : w32 -> w8 = symbolic
(query [(Eq 0
             (ReadLSB w32 0 role_managed))
         (Ult N0:(ReadLSB w32 0 out_offset)
              144)
         (Eq 0
             (ReadLSB w32 0 token))
         (Eq 132
             (ReadLSB w32 0 wl1))
         (Eq false (Ult N0 128))
         (Eq 132
             (ReadLSB w32 0 wl2))
         (Eq (ReadLSB w32 0 secondary_limit)
             (Add w32 N0
                      (ReadLSB w32 0 window_sz)))
         (Eq 0
             (ReadLSB w32 0 role_secondary))
         (Eq 132
             (ReadLSB w32 0 write_limit))
         (Eq false (Ult N0 132))
         (Eq 0
             (ReadLSB w32 0 copy_len))]
        false)
