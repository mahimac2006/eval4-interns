array freed[4] : w32 -> w8 = symbolic
array signal_ungoverned[4] : w32 -> w8 = symbolic
array view_a[4] : w32 -> w8 = symbolic
array view_b[4] : w32 -> w8 = symbolic
(query [(Eq 1
             (ReadLSB w32 0 signal_ungoverned))
         (Eq 0
             (ReadLSB w32 0 freed))
         (Eq false
             (Eq (ReadLSB w32 0 view_a)
                 (ReadLSB w32 0 view_b)))]
        false)
