-/* -------------------------------------------------------------------------
- * Exec handler table
- * ---------------------------------------------------------------------- */
-
-static void psmgr_handler_passthrough(struct psmgr_session *sess,
-				      u8 *data, u32 len)
-{
-}
-
-static void psmgr_handler_verify(struct psmgr_session *sess,
-				 u8 *data, u32 len)
-{
-	u32 i, sum = 0;
-	for (i = 0; i < len; i++)
-		sum += data[i];
-}
-
-static void psmgr_handler_reduce(struct psmgr_session *sess,
-				 u8 *data, u32 len)
-{
-	u32 i;
-	for (i = 0; i + 1 < len; i += 2)
-		data[i] ^= data[i + 1];
-}
-
-static void psmgr_handler_flush(struct psmgr_session *sess,
-				u8 *data, u32 len)
-{
-	memset(data, 0, len);
-}
-
-static psmgr_handler_fn_t psmgr_handlers[PSMGR_HANDLER_MAX] = {
-	psmgr_handler_passthrough,
-	psmgr_handler_verify,
-	psmgr_handler_reduce,
