-		case PSMGR_MODE_INTERLEAVE: return proc_param * 4;
-		case PSMGR_MODE_FOLD:       return proc_param * 8;
-		}
-		break;
-	case PSMGR_XFRM_WINDOW:
-		switch (enc_mode) {
-		case PSMGR_MODE_LINEAR:     return proc_param;
-		case PSMGR_MODE_INTERLEAVE: return proc_param * 2;
-		case PSMGR_MODE_FOLD:       return proc_param * 4;
-		}
-		break;
-	case PSMGR_XFRM_COMMIT:
-		switch (enc_mode) {
-		case PSMGR_MODE_LINEAR:     return proc_param * 4;
-		case PSMGR_MODE_INTERLEAVE: return proc_param * 8;
