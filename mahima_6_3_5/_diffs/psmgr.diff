diff -ruN /Users/mahimachaudhary/Downloads/eval4_linux/net/psmgr/psmgr_core.c /Users/mahimachaudhary/Downloads/eval4_linux_6_6_25/net/psmgr/psmgr_core.c
--- /Users/mahimachaudhary/Downloads/eval4_linux/net/psmgr/psmgr_core.c	1969-12-31 16:00:00
+++ /Users/mahimachaudhary/Downloads/eval4_linux_6_6_25/net/psmgr/psmgr_core.c	2026-07-15 15:15:59
@@ -0,0 +1,653 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * psmgr_core.c - Protocol Session Manager: payload processing path
+ *
+ * Consumer of session state. Implements a processing pipeline governed by
+ * desc->write_count as a write completion counter. Each in-bounds DATA
+ * write increments write_count by one. When write_count reaches
+ * PSMGR_BUF_WRITE_THRESH the buffer is considered complete and the
+ * kernel installs token. COMMIT_REQ is accepted only after completion.
+ * The exec path is gated on PSMGR_BUF_COMMITTED, token non-zero, and
+ * handler non-null.
+ *
+ * Sequence numbers are validated on all message types except PROBE.
+ * CTRL messages carry subtypes that affect session state. PROBE messages
+ * update keepalive state. BRIDGE window updates are applied to session ctx.
+ */
+
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/slab.h>
+#include <linux/net.h>
+#include <linux/socket.h>
+#include <linux/errno.h>
+#include <linux/uio.h>
+#include <linux/poll.h>
+#include <linux/ktime.h>
+#include <net/sock.h>
+#include <net/net_namespace.h>
+#include "psmgr.h"
+
+/* -------------------------------------------------------------------------
+ * Exec handler table
+ * ---------------------------------------------------------------------- */
+
+static void psmgr_handler_passthrough(struct psmgr_session *sess,
+				      u8 *data, u32 len)
+{
+}
+
+static void psmgr_handler_verify(struct psmgr_session *sess,
+				 u8 *data, u32 len)
+{
+	u32 i, sum = 0;
+	for (i = 0; i < len; i++)
+		sum += data[i];
+}
+
+static void psmgr_handler_reduce(struct psmgr_session *sess,
+				 u8 *data, u32 len)
+{
+	u32 i;
+	for (i = 0; i + 1 < len; i += 2)
+		data[i] ^= data[i + 1];
+}
+
+static void psmgr_handler_flush(struct psmgr_session *sess,
+				u8 *data, u32 len)
+{
+	memset(data, 0, len);
+}
+
+static psmgr_handler_fn_t psmgr_handlers[PSMGR_HANDLER_MAX] = {
+	psmgr_handler_passthrough,
+	psmgr_handler_verify,
+	psmgr_handler_reduce,
+	psmgr_handler_flush,
+};
+
+/* -------------------------------------------------------------------------
+ * Sequence number validation
+ * ---------------------------------------------------------------------- */
+
+static int psmgr_check_seq(struct psmgr_session *sess, u32 seq, u8 msg_type)
+{
+	if (msg_type == PSMGR_MSG_PROBE)
+		return 0;
+
+	if (seq != sess->next_seq) {
+		sess->stats.seq_errors++;
+		pr_debug("psmgr: session %u seq error: expected %u got %u\n",
+				 sess->session_id, sess->next_seq, seq);
+		return -EILSEQ;
+	}
+	/*
+	 * Sequence space exhausted after this message. Accept the message
+	 * (seq == next_seq is valid), then poison the session so no further
+	 * message can arrive with a valid sequence number. next_seq is left
+	 * at UINT_MAX; any subsequent seq value will fail the equality check
+	 * above permanently.
+	 */
+	if (sess->next_seq == UINT_MAX) {
+		pr_debug("psmgr: session %u seq exhausted after seq=%u, session poisoned\n",
+				 sess->session_id, seq);
+		sess->stats.seq_errors++;
+		return 0;   /* accept this final message, do not increment */
+	}
+	sess->next_seq++;
+	return 0;
+}
+
+/* -------------------------------------------------------------------------
+ * out_offset computation
+ * ---------------------------------------------------------------------- */
+
+static u32 compute_out_offset(u8 xfrm_type, u8 enc_mode, u32 proc_param)
+{
+	switch (xfrm_type) {
+	case PSMGR_XFRM_SCATTER:
+		switch (enc_mode) {
+		case PSMGR_MODE_LINEAR:     return proc_param * 2;
+		case PSMGR_MODE_INTERLEAVE: return proc_param * 4;
+		case PSMGR_MODE_FOLD:       return proc_param * 8;
+		}
+		break;
+	case PSMGR_XFRM_WINDOW:
+		switch (enc_mode) {
+		case PSMGR_MODE_LINEAR:     return proc_param;
+		case PSMGR_MODE_INTERLEAVE: return proc_param * 2;
+		case PSMGR_MODE_FOLD:       return proc_param * 4;
+		}
+		break;
+	case PSMGR_XFRM_COMMIT:
+		switch (enc_mode) {
+		case PSMGR_MODE_LINEAR:     return proc_param * 4;
+		case PSMGR_MODE_INTERLEAVE: return proc_param * 8;
+		case PSMGR_MODE_FOLD:       return proc_param * 16;
+		}
+		break;
+	case PSMGR_XFRM_REFLECT:
+		switch (enc_mode) {
+		case PSMGR_MODE_LINEAR:     return proc_param;
+		case PSMGR_MODE_INTERLEAVE: return (proc_param ^ (proc_param >> 1)) * 2;
+		case PSMGR_MODE_FOLD:       return proc_param * 4;
+		}
+		break;
+	}
+	return UINT_MAX;
+}
+
+/* -------------------------------------------------------------------------
+ * token computation
+ * ---------------------------------------------------------------------- */
+
+static void psmgr_compute_token(struct psmgr_session *sess)
+{
+	sess->desc->token =
+		(sess->session_id ^ sess->nonce ^ 0xA5C3E1F0) | 0x80000000;
+	pr_debug("psmgr: session %u token set: 0x%08x\n",
+			 sess->session_id, sess->desc->token);
+}
+
+/* -------------------------------------------------------------------------
+ * Completion counter update
+ *
+ * Called after every DATA write.
+ *
+ * When write_count reaches PSMGR_BUF_WRITE_THRESH and token has not
+ * yet been set, the kernel computes and installs token.
+ * ---------------------------------------------------------------------- */
+
+static void psmgr_write_count_update(struct psmgr_session *sess, u32 out_offset)
+{
+	struct psmgr_desc *pb = sess->desc;
+
+	if (out_offset < PSMGR_BUF_DATA_SZ) {
+		/* Increment the completion counter, capped at the threshold. */
+		if (pb->write_count < PSMGR_BUF_WRITE_THRESH)
+			pb->write_count++;
+	}
+
+	if (pb->write_count >= PSMGR_BUF_WRITE_THRESH && pb->token == 0) {
+		psmgr_compute_token(sess);
+		pr_debug("psmgr: session %u buffer complete, token set\n",
+				 sess->session_id);
+	}
+}
+
+/* -------------------------------------------------------------------------
+ * DATA message processing
+ * ---------------------------------------------------------------------- */
+
+static int psmgr_process_data(struct psmgr_session *sess,
+			      const u8 *payload, u16 payload_len)
+{
+	struct psmgr_desc *pb = sess->desc;
+	u32 out_offset;
+	u32 write_limit;
+	u16 copy_len;
+
+	if (sess->paused) {
+		pr_debug("psmgr: session %u DATA rejected: session paused\n",
+				 sess->session_id);
+		return -EBUSY;
+	}
+
+	if (pb->write_count == PSMGR_BUF_COMMITTED) {
+		pr_debug("psmgr: session %u DATA rejected: already finalized\n",
+				 sess->session_id);
+		return -EPROTO;
+	}
+
+	out_offset = compute_out_offset(sess->ctx.xfrm_type,
+					sess->ctx.enc_mode,
+					sess->ctx.proc_param);
+
+	if (out_offset == UINT_MAX) {
+		pr_debug("psmgr: session %u unknown xfrm/enc_mode\n",
+				 sess->session_id);
+		return -EPROTO;
+	}
+
+	/*
+	 * Per-transform semantic validation.
+	 *
+	 * SCATTER: offset must be stride-aligned and within the data region.
+	 * COMMIT:  offset must be 4-byte aligned and within the data region.
+	 * REFLECT: reflected offset must lie within the data region.
+	 * WINDOW:  handshake guarantee is the validator.
+	 */
+	switch (sess->ctx.xfrm_type) {
+	case PSMGR_XFRM_SCATTER: {
+		u32 stride = (sess->ctx.enc_mode == PSMGR_MODE_LINEAR)    ? 2 :
+					 (sess->ctx.enc_mode == PSMGR_MODE_INTERLEAVE) ? 4 : 8;
+		if (out_offset >= PSMGR_BUF_DATA_SZ ||
+			(out_offset % stride) != 0) {
+			pr_debug("psmgr: session %u SCATTER offset invalid: "
+					 "out_offset=%u stride=%u\n",
+					 sess->session_id, out_offset, stride);
+			return -EPROTO;
+		}
+		break;
+	}
+	case PSMGR_XFRM_COMMIT:
+		if (out_offset >= PSMGR_BUF_DATA_SZ || (out_offset & 0x3) != 0) {
+			pr_debug("psmgr: session %u COMMIT offset invalid: "
+					 "out_offset=%u\n", sess->session_id, out_offset);
+			return -EPROTO;
+		}
+		break;
+	case PSMGR_XFRM_REFLECT:
+		if (out_offset >= PSMGR_BUF_DATA_SZ) {
+			pr_debug("psmgr: session %u REFLECT offset out of region: "
+					 "out_offset=%u\n", sess->session_id, out_offset);
+			return -EPROTO;
+		}
+		break;
+	case PSMGR_XFRM_WINDOW:
+		break;
+	}
+
+	/*
+	 * Global upper bound: reject writes beyond the end of desc.
+	 */
+	if (sess->role != PSMGR_ROLE_MANAGED &&
+		out_offset >= PSMGR_BUF_TOTAL_SZ) {
+		pr_debug("psmgr: session %u DATA rejected: out_offset=%u >= BUF_TOTAL_SZ\n",
+				 sess->session_id, out_offset);
+		return -ERANGE;
+	}
+
+	if (pb->token != 0)
+		write_limit = PSMGR_BUF_TOTAL_SZ;
+	else
+		write_limit = PSMGR_BUF_DATA_SZ + (u32)sizeof(u32);
+
+	if (out_offset < PSMGR_BUF_DATA_SZ && write_limit > PSMGR_BUF_DATA_SZ)
+		write_limit = PSMGR_BUF_DATA_SZ;
+
+	/* BRIDGE: apply window_sz limit if set */
+	if (sess->role == PSMGR_ROLE_BRIDGE && sess->ctx.window_sz > 0) {
+		u32 bridge_limit = (u32)out_offset + (u32)sess->ctx.window_sz;
+		if (bridge_limit < write_limit)
+			write_limit = bridge_limit;
+	}
+
+	copy_len = min_t(u16, payload_len,
+					 (u16)(write_limit -
+						   min_t(u32, out_offset, write_limit)));
+
+	if (copy_len == 0)
+		return 0;
+
+	memcpy((u8 *)pb + out_offset, payload, copy_len);
+
+	psmgr_write_count_update(sess, out_offset);
+
+	sess->stats.data_msgs_rx++;
+	sess->stats.data_bytes_rx += copy_len;
+	sess->stats.last_rx = ktime_get();
+
+	if (sess->sk)
+		sess->sk->sk_data_ready(sess->sk);
+
+	return (int)copy_len;
+}
+
+/* -------------------------------------------------------------------------
+ * CTRL message processing
+ * ---------------------------------------------------------------------- */
+
+static int psmgr_process_ctrl(struct psmgr_session *sess,
+			      const u8 *payload, u16 payload_len)
+{
+	struct psmgr_ctrl_payload cp;
+
+	if (payload_len < sizeof(cp))
+		return -EINVAL;
+
+	memcpy(&cp, payload, sizeof(cp));
+
+	switch (cp.subtype) {
+	case PSMGR_CTRL_RESET: {
+		if (sess->desc->token != 0) {
+			pr_debug("psmgr: session %u CTRL RESET rejected: token set\n",
+					 sess->session_id);
+			return -EPROTO;
+		}
+		memset(sess->desc, 0, sizeof(*sess->desc));
+		sess->next_seq = 0;
+		pr_debug("psmgr: session %u CTRL RESET\n", sess->session_id);
+		break;
+	}
+	case PSMGR_CTRL_PAUSE:
+		sess->paused = 1;
+		pr_debug("psmgr: session %u CTRL PAUSE\n", sess->session_id);
+		break;
+	case PSMGR_CTRL_RESUME:
+		sess->paused = 0;
+		pr_debug("psmgr: session %u CTRL RESUME\n", sess->session_id);
+		break;
+	case PSMGR_CTRL_STATUS_REQ:
+		pr_debug("psmgr: session %u CTRL STATUS_REQ write_count=%u\n",
+				 sess->session_id, sess->desc->write_count);
+		break;
+	default:
+		pr_debug("psmgr: session %u CTRL unknown subtype=0x%02x\n",
+				 sess->session_id, cp.subtype);
+		return -EPROTO;
+	}
+
+	sess->stats.ctrl_msgs_rx++;
+	sess->stats.last_rx = ktime_get();
+	return 0;
+}
+
+static int psmgr_process_commit_req(struct psmgr_session *sess,
+				    const u8 *payload, u16 payload_len)
+{
+	struct psmgr_desc *pb = sess->desc;
+	struct psmgr_commit_req_payload cpl;
+
+	if (pb->write_count == PSMGR_BUF_COMMITTED ||
+		pb->write_count < PSMGR_BUF_WRITE_THRESH ||
+		pb->token == 0) {
+		pr_debug("psmgr: session %u COMMIT_REQ rejected: "
+				 "write_count=0x%08x token=0x%08x\n",
+				 sess->session_id, pb->write_count, pb->token);
+		return -EPROTO;
+	}
+
+	if (pb->handler != NULL) {
+		/* Handler already installed; skip table resolution. */
+		pr_debug("psmgr: session %u COMMIT_REQ: handler pre-installed\n",
+				 sess->session_id);
+	} else {
+		if (payload_len < sizeof(cpl))
+			return -EINVAL;
+		memcpy(&cpl, payload, sizeof(cpl));
+		if (cpl.handler_idx >= PSMGR_HANDLER_MAX) {
+			pr_debug("psmgr: session %u COMMIT_REQ: handler_idx=%u out of range\n",
+					 sess->session_id, cpl.handler_idx);
+			return -ERANGE;
+		}
+		pb->handler = psmgr_handlers[cpl.handler_idx];
+		pr_debug("psmgr: session %u COMMIT_REQ: handler[%u] installed\n",
+				 sess->session_id, cpl.handler_idx);
+	}
+
+	pb->write_count = PSMGR_BUF_COMMITTED;
+	pr_debug("psmgr: session %u COMMIT_REQ: finalized\n", sess->session_id);
+
+	sess->stats.commit_reqs_rx++;
+	sess->stats.last_rx = ktime_get();
+	return 0;
+}
+
+/* -------------------------------------------------------------------------
+ * poll
+ *
+ * Reports readability when desc state has changed since the last
+ * recvmsg (i.e. any DATA write has occurred or the buffer is complete).
+ * Writability is always reported: sendmsg does not block.
+ * ---------------------------------------------------------------------- */
+
+__poll_t psmgr_poll(struct file *file, struct socket *sock,
+		    struct poll_table_struct *wait)
+{
+	struct sock *sk = sock->sk;
+	struct psmgr_sock *psk = psmgr_sk(sk);
+	struct psmgr_session *sess = psk->session;
+	__poll_t mask = EPOLLOUT | EPOLLWRNORM;
+
+	sock_poll_wait(file, sock, wait);
+
+	if (!sess || !sess->validated)
+		return mask;
+
+	spin_lock_bh(&sess->lock);
+	if (sess->desc->write_count > 0 || sess->desc->token != 0)
+		mask |= EPOLLIN | EPOLLRDNORM;
+	spin_unlock_bh(&sess->lock);
+
+	return mask;
+}
+
+/* -------------------------------------------------------------------------
+ * sendmsg dispatch
+ * ---------------------------------------------------------------------- */
+
+int psmgr_sendmsg(struct socket *sock, struct msghdr *msg, size_t len)
+{
+	struct sock *sk = sock->sk;
+	struct psmgr_sock *psk = psmgr_sk(sk);
+	struct psmgr_session *sess = psk->session;
+	struct psmgr_msghdr hdr;
+	u8 *payload = NULL;
+	u16 payload_len;
+	int ret = 0;
+
+	if (!sess || !sess->validated)
+		return -ENOTCONN;
+	if (len < PSMGR_MSGHDR_SZ)
+		return -EINVAL;
+	if (len > PSMGR_MSG_MAX_SZ)
+		return -EMSGSIZE;
+
+	if (sess->role == PSMGR_ROLE_FORWARD) {
+		/*
+		 * FORWARD sessions relay messages to the peer without processing.
+		 * The peer must be connected; if not, the session is not yet usable.
+		 */
+		spin_lock_bh(&sess->lock);
+		if (!sess->peer || !sess->validated) {
+			spin_unlock_bh(&sess->lock);
+			return -ENOTCONN;
+		}
+		sess->stats.data_msgs_rx++;
+		sess->stats.last_rx = ktime_get();
+		if (sess->peer->sk)
+			sess->peer->sk->sk_data_ready(sess->peer->sk);
+		spin_unlock_bh(&sess->lock);
+		return (int)len;
+	}
+
+	if (copy_from_iter(&hdr, PSMGR_MSGHDR_SZ, &msg->msg_iter) != PSMGR_MSGHDR_SZ)
+		return -EFAULT;
+
+	if ((hdr.session_id_lo & 0xFF) != (sess->session_id & 0xFF)) {
+		pr_debug("psmgr: session %u session_id_lo mismatch: "
+				 "expected 0x%02x got 0x%02x\n",
+				 sess->session_id,
+				 (u8)(sess->session_id & 0xFF),
+				 hdr.session_id_lo);
+		return -EBADFD;
+	}
+
+	if (hdr.msg_type == PSMGR_MSG_WINDOW_UPD) {
+		struct psmgr_window_upd_payload wup;
+		u16 wup_len;
+
+		if (sess->role != PSMGR_ROLE_BRIDGE)
+			return -EOPNOTSUPP;
+
+		wup_len = min_t(u16, hdr.payload_len, (u16)sizeof(wup));
+		if (wup_len < sizeof(wup))
+			return -EINVAL;
+		if (copy_from_iter(&wup, sizeof(wup),
+						   &msg->msg_iter) != sizeof(wup))
+			return -EFAULT;
+		if (wup.new_window_sz == 0 ||
+			wup.new_window_sz > PSMGR_BUF_DATA_SZ)
+			return -ERANGE;
+
+		spin_lock_bh(&sess->lock);
+		ret = psmgr_check_seq(sess, hdr.seq, hdr.msg_type);
+		if (ret == 0) {
+			sess->ctx.window_sz = wup.new_window_sz;
+			sess->stats.last_rx = ktime_get();
+			pr_debug("psmgr: session %u WINDOW_UPD new_window_sz=%u\n",
+					 sess->session_id, wup.new_window_sz);
+			ret = (int)len;
+		}
+		spin_unlock_bh(&sess->lock);
+		return ret;
+	}
+
+	switch (hdr.msg_type) {
+	case PSMGR_MSG_DATA:
+		payload_len = min_t(u16, hdr.payload_len, PSMGR_BUF_DATA_SZ);
+		break;
+	case PSMGR_MSG_COMMIT_REQ:
+		payload_len = min_t(u16, hdr.payload_len,
+							(u16)sizeof(struct psmgr_commit_req_payload));
+		break;
+	case PSMGR_MSG_CTRL:
+		payload_len = min_t(u16, hdr.payload_len,
+							(u16)sizeof(struct psmgr_ctrl_payload));
+		break;
+	default:
+		payload_len = 0;
+		break;
+	}
+
+	if (payload_len > 0) {
+		payload = kmalloc(payload_len, GFP_KERNEL);
+		if (!payload)
+			return -ENOMEM;
+		if (copy_from_iter(payload, payload_len,
+						   &msg->msg_iter) != payload_len) {
+			kfree(payload);
+			return -EFAULT;
+		}
+	}
+
+	spin_lock_bh(&sess->lock);
+
+	ret = psmgr_check_seq(sess, hdr.seq, hdr.msg_type);
+	if (ret) {
+		spin_unlock_bh(&sess->lock);
+		kfree(payload);
+		return ret;
+	}
+
+	switch (hdr.msg_type) {
+
+	case PSMGR_MSG_DATA:
+		ret = psmgr_process_data(sess, payload, payload_len);
+		if (ret >= 0) ret = (int)len;
+		break;
+
+	case PSMGR_MSG_COMMIT_REQ:
+		ret = psmgr_process_commit_req(sess, payload, payload_len);
+		if (ret >= 0) ret = (int)len;
+		break;
+
+	case PSMGR_MSG_PROBE:
+		sess->stats.probe_msgs_rx++;
+		sess->stats.last_rx = ktime_get();
+		ret = (int)len;
+		break;
+
+	case PSMGR_MSG_CTRL:
+		ret = psmgr_process_ctrl(sess, payload, payload_len);
+		if (ret >= 0) ret = (int)len;
+		break;
+
+	default:
+		ret = -EPROTO;
+		break;
+	}
+
+	spin_unlock_bh(&sess->lock);
+	kfree(payload);
+
+	return ret;
+}
+
+/* -------------------------------------------------------------------------
+ * recvmsg
+ * ---------------------------------------------------------------------- */
+
+struct psmgr_desc_export {
+	u8   data[PSMGR_BUF_DATA_SZ];
+	u32  write_count;
+	u32  token;
+	u8   handler_set;
+	u8   reserved[7];
+};
+
+int psmgr_recvmsg(struct socket *sock, struct msghdr *msg, size_t len,
+		  int flags)
+{
+	struct sock *sk = sock->sk;
+	struct psmgr_sock *psk = psmgr_sk(sk);
+	struct psmgr_session *sess = psk->session;
+	struct psmgr_desc_export exp;
+
+	if (!sess || !sess->validated)
+		return -ENOTCONN;
+
+	if (len < sizeof(exp))
+		return -EINVAL;
+
+	memset(&exp, 0, sizeof(exp));
+	spin_lock_bh(&sess->lock);
+	memcpy(exp.data, sess->desc->data, PSMGR_BUF_DATA_SZ);
+	exp.write_count  = sess->desc->write_count;
+	exp.token  = sess->desc->token;
+	exp.handler_set = (sess->desc->handler != NULL) ? 1 : 0;
+	spin_unlock_bh(&sess->lock);
+
+	if (copy_to_iter(&exp, sizeof(exp), &msg->msg_iter) != sizeof(exp))
+		return -EFAULT;
+
+	return sizeof(exp);
+}
+
+/* -------------------------------------------------------------------------
+ * exec path
+ * ---------------------------------------------------------------------- */
+
+int psmgr_exec(struct psmgr_session *sess)
+{
+	struct psmgr_desc *pb = sess->desc;
+	u8 data_copy[PSMGR_BUF_DATA_SZ];
+	u32 token;
+	u32 write_count;
+	psmgr_handler_fn_t fn;
+
+	spin_lock_bh(&sess->lock);
+	token = pb->token;
+	write_count = pb->write_count;
+	fn         = pb->handler;
+	memcpy(data_copy, pb->data, PSMGR_BUF_DATA_SZ);
+	sess->stats.exec_calls++;
+	spin_unlock_bh(&sess->lock);
+
+	if (write_count != PSMGR_BUF_COMMITTED) {
+		pr_debug("psmgr: session %u exec rejected: not finalized\n",
+				 sess->session_id);
+		return -EPROTO;
+	}
+
+	if (token == 0) {
+		pr_debug("psmgr: session %u exec rejected: token not set\n",
+				 sess->session_id);
+		return -EACCES;
+	}
+
+	if (fn == NULL) {
+		pr_debug("psmgr: session %u exec rejected: handler not set\n",
+				 sess->session_id);
+		return -ENOENT;
+	}
+
+	fn(sess, data_copy, PSMGR_BUF_DATA_SZ);
+
+	spin_lock_bh(&sess->lock);
+	memcpy(pb->data, data_copy, PSMGR_BUF_DATA_SZ);
+	spin_unlock_bh(&sess->lock);
+
+	return 0;
+}
