array desc_buf_size[8] : w32 -> w8 = symbolic
array desc_count[8] : w32 -> w8 = symbolic
array i[8] : w32 -> w8 = symbolic
(query [(Ule (Mul w64 16
                       N0:(ReadLSB w64 0 desc_count))
              N1:(ReadLSB w64 0 desc_buf_size))
         (Ult N2:(ReadLSB w64 0 i)
              N0)
         (Eq false
             (Ule (Add w64 16 (Mul w64 16 N2))
                  N1))]
        false)
