array content_attacker[4] : w32 -> w8 = symbolic
array content_trusted[4] : w32 -> w8 = symbolic
array resource_inconsistent[4] : w32 -> w8 = symbolic
array resource_live[4] : w32 -> w8 = symbolic
(query [(Eq 1
             (ReadLSB w32 0 resource_live))
         (Eq 1
             (ReadLSB w32 0 resource_inconsistent))
         (Eq 1
             (ReadLSB w32 0 content_attacker))
         (Eq false
             (Eq 1
                 (ReadLSB w32 0 content_trusted)))]
        false)
