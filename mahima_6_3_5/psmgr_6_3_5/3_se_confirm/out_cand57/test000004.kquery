array copy_len[4] : w32 -> w8 = symbolic
array out_offset[4] : w32 -> w8 = symbolic
array role[4] : w32 -> w8 = symbolic
array token[4] : w32 -> w8 = symbolic
array wl0[4] : w32 -> w8 = symbolic
array wl1[4] : w32 -> w8 = symbolic
array write_limit[4] : w32 -> w8 = symbolic
array xfrm_type[4] : w32 -> w8 = symbolic
(query [(Eq 3
             (ReadLSB w32 0 xfrm_type))
         (Eq 0
             (ReadLSB w32 0 role))
         (Eq N0:(ReadLSB w32 0 wl0)
             (Select w32 (Eq false
                             (Eq 0
                                 (ReadLSB w32 0 token)))
                         144
                         132))
         (Eq false
             (Ult N1:(ReadLSB w32 0 out_offset)
                  128))
         (Eq N2:(ReadLSB w32 0 wl1)
             N0)
         (Eq N3:(ReadLSB w32 0 write_limit)
             N2)
         (Eq false (Ult N1 N3))
         (Eq 0
             (ReadLSB w32 0 copy_len))]
        false)
