array token[4] : w32 -> w8 = symbolic
array write_count[4] : w32 -> w8 = symbolic
(query [(Eq false
             (Eq 4294967295
                 N0:(ReadLSB w32 0 write_count)))
         (Ule 64 N0)
         (Eq false
             (Eq 0
                 (ReadLSB w32 0 token)))
         (Eq false (Ule N0 128))]
        false)
