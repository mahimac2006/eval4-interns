array access_index[4] : w32 -> w8 = symbolic
array bound[4] : w32 -> w8 = symbolic
array content_attacker[4] : w32 -> w8 = symbolic
array content_authoritative[4] : w32 -> w8 = symbolic
(query [(Eq 1
             (ReadLSB w32 0 content_authoritative))
         (Eq 1
             (ReadLSB w32 0 content_attacker))
         (Sle 1
              N0:(ReadLSB w32 0 bound))
         (Sle 0
              N1:(ReadLSB w32 0 access_index))
         (Eq false (Slt N1 N0))]
        false)
