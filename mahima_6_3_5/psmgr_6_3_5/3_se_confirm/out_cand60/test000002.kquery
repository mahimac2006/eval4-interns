array copy_len[4] : w32 -> w8 = symbolic
array out_offset[4] : w32 -> w8 = symbolic
array payload_len[4] : w32 -> w8 = symbolic
array write_limit[4] : w32 -> w8 = symbolic
(query [(Ule N0:(ReadLSB w32 0 copy_len)
              (ReadLSB w32 0 payload_len))
         (Ult N1:(ReadLSB w32 0 out_offset)
              N2:(ReadLSB w32 0 write_limit))
         (Ule N0 (Sub w32 N2 N1))
         (Ult 0 N0)
         (Eq false
             (Ule (Add w32 N1 N0) 128))]
        false)
